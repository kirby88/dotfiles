# Exit code to display, to load after the timer
__exit_code_precmd() {
    result=$(echo $?)
    if [ $result -eq 0 ]; then
        local cols=$((COLUMNS - ${#tdiffstr} - 3))
        echo -e "вң…\033[${cols}C ${tdiffstr}"
        #echo -e "\033[42m\033[30m вң…$(printf '%*s' ${cols}) ${tdiffstr}\033[0m"
    else
        local cols=$((COLUMNS - ${#tdiffstr} - 14 - ${#result}))
        echo -e "\033[31mвқҢ Exit code ${result}\033[0m\033[${cols}C ${tdiffstr}"
        #echo -e "\033[41m вқҢ Exit code ${result}$(printf '%*s' ${cols}) ${tdiffstr}\033[0m"
    fi
  #echo -e "%F{black}%(?.%K{green} вң….%K{red} вқҢ) ${tdiffstr} %(?.%k. Exit code %? %k)%f"$'\n\n'
  print ""
}

autoload -U add-zsh-hook
add-zsh-hook precmd __exit_code_precmd


